{
    "version": "2.0",
    "logging": {
        "logLevel": {
            "Function.HealthCheck": "Warning"
        },
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true,
                "excludedTypes": "Exception"
            }
        }
    },
    "extensions": {
        "serviceBus": {
            "maxConcurrentCalls": 8,
            "maxAutoLockRenewalDuration": "00:10:00",
            "autoCompleteMessages": true
        }
    }
}